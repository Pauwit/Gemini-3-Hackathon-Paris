# === BACKEND ===
PORT=3001
MODE=live
USE_MOCK=false
GEMINI_API_KEY=your_gemini_api_key_here

# === FRONTEND ===
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ENABLE_VISION=true
NEXT_PUBLIC_ENABLE_MEMORY=true
# Google OAuth client ID (format: xxxxxxxxx.apps.googleusercontent.com)
# Get one at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Leave blank to use demo mode instead
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id_here
